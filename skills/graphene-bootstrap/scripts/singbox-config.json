{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "type": "udp",
        "tag": "tor-dns",
        "server": "127.0.0.1",
        "server_port": 5400
      }
    ],
    "final": "tor-dns"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": ["172.19.0.1/30"],
      "mtu": 1500,
      "auto_route": true,
      "strict_route": true,
      "stack": "gvisor",
      "exclude_package": [
        "io.nekohasekai.sfa",
        "org.torproject.android",
        "org.torproject.torbrowser",
        "com.cakewallet.cake_wallet",
        "com.monero.app",
        "com.cypherstack.stackwallet",
        "app.grapheneos.update.client"
      ]
    }
  ],
  "outbounds": [
    {
      "type": "socks",
      "tag": "tor-firefox",
      "server": "127.0.0.1",
      "server_port": 9053
    },
    {
      "type": "socks",
      "tag": "tor-brave",
      "server": "127.0.0.1",
      "server_port": 9054
    },
    {
      "type": "socks",
      "tag": "tor-jelly",
      "server": "127.0.0.1",
      "server_port": 9055
    },
    {
      "type": "socks",
      "tag": "tor-conversations",
      "server": "127.0.0.1",
      "server_port": 9056
    },
    {
      "type": "socks",
      "tag": "tor-threema",
      "server": "127.0.0.1",
      "server_port": 9057
    },
    {
      "type": "socks",
      "tag": "tor-session",
      "server": "127.0.0.1",
      "server_port": 9058
    },
    {
      "type": "socks",
      "tag": "tor-element",
      "server": "127.0.0.1",
      "server_port": 9059
    },
    {
      "type": "socks",
      "tag": "tor-hypatia",
      "server": "127.0.0.1",
      "server_port": 9060
    },
    {
      "type": "socks",
      "tag": "tor-fluffychat",
      "server": "127.0.0.1",
      "server_port": 9061
    },
    {
      "type": "socks",
      "tag": "tor-schildichat",
      "server": "127.0.0.1",
      "server_port": 9062
    },
    {
      "type": "socks",
      "tag": "tor-atalk",
      "server": "127.0.0.1",
      "server_port": 9063
    },
    {
      "type": "socks",
      "tag": "tor-vanadium",
      "server": "127.0.0.1",
      "server_port": 9064
    },
    {
      "type": "socks",
      "tag": "tor-auditor",
      "server": "127.0.0.1",
      "server_port": 9065
    },
    {
      "type": "socks",
      "tag": "tor-simplex",
      "server": "127.0.0.1",
      "server_port": 9066
    },
    {
      "type": "socks",
      "tag": "tor-tuta",
      "server": "127.0.0.1",
      "server_port": 9067
