    {
      "type": "socks",
      "tag": "tor-protonmail",
      "server": "127.0.0.1",
      "server_port": 9068
    },
    {
      "type": "socks",
      "tag": "tor-shared",
      "server": "127.0.0.1",
      "server_port": 9052
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff",
        "timeout": "300ms"
      },
      {
        "protocol": ["dns"],
        "action": "hijack-dns"
      },
      {
        "package_name": ["org.mozilla.firefox"],
        "action": "route",
        "outbound": "tor-firefox"
      },
      {
        "package_name": ["com.brave.browser"],
        "action": "route",
        "outbound": "tor-brave"
      },
      {
        "package_name": ["org.lineageos.jelly"],
        "action": "route",
        "outbound": "tor-jelly"
      },
      {
        "package_name": ["eu.siacs.conversations"],
        "action": "route",
        "outbound": "tor-conversations"
      },
      {
        "package_name": ["ch.threema.app.libre"],
        "action": "route",
        "outbound": "tor-threema"
      },
      {
        "package_name": ["network.loki.messenger"],
        "action": "route",
        "outbound": "tor-session"
      },
      {
        "package_name": ["io.element.android.x"],
        "action": "route",
        "outbound": "tor-element"
      },
      {
        "package_name": ["org.maintainteam.hypatia"],
        "action": "route",
        "outbound": "tor-hypatia"
      },
      {
        "package_name": ["chat.fluffy.fluffychat"],
        "action": "route",
        "outbound": "tor-fluffychat"
      },
      {
        "package_name": ["chat.schildi.android"],
        "action": "route",
        "outbound": "tor-schildichat"
      },
      {
        "package_name": ["org.atalk.android"],
        "action": "route",
        "outbound": "tor-atalk"
      },
      {
        "package_name": ["app.vanadium.browser", "app.vanadium.config"],
        "action": "route",
        "outbound": "tor-vanadium"
      },
      {
        "package_name": ["app.attestation.auditor"],
        "action": "route",
        "outbound": "tor-auditor"
      },
      {
        "package_name": ["chat.simplex.app"],
        "action": "route",
        "outbound": "tor-simplex"
      },
      {
        "package_name": ["de.tutao.tutanota"],
        "action": "route",
        "outbound": "tor-tuta"
      },
      {
        "package_name": ["ch.protonmail.android"],
        "action": "route",
        "outbound": "tor-protonmail"
      }
    ],
    "final": "tor-shared",
    "auto_detect_interface": true
  }
}
